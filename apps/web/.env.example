# apps/web — required environment variables
# Copy to .env for local development

# Clerk production secret key (D-03: production instance from day 1)
# CRITICAL: Never prefix with VITE_ — would embed secret key in browser bundle
CLERK_SECRET_KEY=sk_test_...

# Clerk production publishable key (D-03: production instance from day 1)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# API base URL
VITE_API_URL=http://localhost:8080

# Clerk setup
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
