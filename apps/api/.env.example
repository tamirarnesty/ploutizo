# apps/api — set these in Railway → api service → Variables (NOT project-level)
# Copy to .env for local development. Never commit .env files.

# Neon direct connection URL (NOT the pooler variant — postgres.js manages its own pool)
# CRITICAL: Never prefix with VITE_ — would embed DB URL in browser bundle
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname

# Clerk secret key
# CRITICAL: Never prefix with VITE_ — would embed secret key in browser bundle
CLERK_SECRET_KEY=sk_live_...

# Clerk publishable key (required by @hono/clerk-auth for JWT verification)
CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk webhook signing secret (Clerk Dashboard → Configure → Webhooks → Signing secret)
CLERK_WEBHOOK_SECRET=whsec_...

# Port (Railway sets this automatically — only set locally if needed)
PORT=8080
