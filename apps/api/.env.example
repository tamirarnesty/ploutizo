# ploutizo — root .env.example
# This file documents ALL environment variables used across the monorepo.
# Individual service .env.example files live at apps/api/.env.example and apps/web/.env.example.
# Never commit .env files.

# ==========================================
# apps/api — set at Railway api service level
# ==========================================

# Neon direct connection URL (NOT the -pooler variant — postgres.js manages its own pool)
# CRITICAL: Never prefix with VITE_ — would embed DB URL in browser bundle
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname

# Clerk production secret key (D-03: production instance from day 1)
# CRITICAL: Never prefix with VITE_ — would embed secret key in browser bundle
CLERK_SECRET_KEY=sk_live_...

# Clerk webhook signing secret (from Clerk Dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=whsec_...

# Port (Railway sets this automatically)
PORT=8080
