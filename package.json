{
  "name": "ploutizo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "test -d .git && lefthook install || true",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.1.2",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "iconv-lite@0.6.3": "0.7.2",
      "typescript-eslint": "^8.58.0"
    }
  }
}
